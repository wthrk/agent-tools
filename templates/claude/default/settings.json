{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/startup.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cmux-notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-git.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-tail-head.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ask-codex@hiropon-plugins": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "language": "丁寧な情報士官",
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.3",
  "skipDangerousModePermissionPrompt": true
}
